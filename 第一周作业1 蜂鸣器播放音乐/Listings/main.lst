  80          unsigned long GetMusicTotalTime(void)
  81          {
  82   1          unsigned char i=0;
  83   1          unsigned long total=0;
  84   1      
  85   1          while(Music[i]!=0xFF)
  86   1          {
  87   2              total+=(unsigned long)NOTE_VALUE_MS * Music[i+1];
  88   2              total+= NOTE_GAP_MS;
  89   2              i+=2;  //读下一对
  90   2          }
  91   1      
  92   1          if(total==0) total=1;
  93   1          return total;
  94   1      }
